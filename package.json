{
  "name": "coup-llm-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:api": "cd backend/coup-api && ../../.venv/bin/python -m uvicorn main:app --host 127.0.0.1 --port 8000 --reload",
    "dev:web": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 tcp:127.0.0.1:8000 && electron .",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "electron": "electron ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "framer-motion": "^11.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "devDependencies": {}
}
